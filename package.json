{
  "name": "@bonhollow/agentforge",
  "version": "0.1.0",
  "description": "Universal CLI to manage, sync and export AI agents, prompts and skills across every coding platform",
  "type": "module",
  "bin": {
    "af": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "files": [
    "dist",
    "static"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@supabase/supabase-js": "^2.49.1",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "defu": "^6.1.4",
    "diff": "^7.0.0",
    "figlet": "^1.11.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.1",
    "@types/figlet": "^1.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.9",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
